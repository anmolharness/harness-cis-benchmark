# Harness CIS Benchmark Agent Configuration
# Copy this file to .env and fill in your values

# Required: Harness API credentials
HARNESS_API_KEY=your_harness_api_key_here
HARNESS_ACCOUNT_ID=your_harness_account_id_here

# Optional: Flask configuration
FLASK_ENV=production
FLASK_RUN_PORT=5000

# Optional: Logging
LOG_LEVEL=INFO
